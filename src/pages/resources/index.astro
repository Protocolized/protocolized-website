---
import Base from "../../layouts/Base.astro";
import BadgeType from "../../components/BadgeType.astro";
import { getCollection } from "astro:content";

const allResources = await getCollection("resources");
const resources = allResources
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .map((r) => ({
    slug: r.slug,
    title: r.data.title,
    type: r.data.type,
    mediaType: ["talk", "lecture", "presentation"].includes(r.data.type) ? "video" : "text",
    description: r.data.description,
    authors: r.data.authors,
    date: r.data.date.toISOString(),
    tags: r.data.tags,
    audience: r.data.audience,
    featured: r.data.featured,
  }));

const allTypes = [...new Set(allResources.map((r) => r.data.type))].sort();
const allAudiences = [
  "researcher",
  "practitioner",
  "academic",
  "corporate",
] as const;
const allTags = [
  ...new Set(allResources.flatMap((r) => r.data.tags)),
].sort();

const typeLabels: Record<string, string> = {
  paper: "Paper",
  "working-paper": "Working Paper",
  framework: "Framework",
  "workshop-template": "Workshop Template",
  game: "Game",
  dataset: "Dataset",
  interview: "Interview",
  presentation: "Presentation",
  code: "Code",
  image: "Image",
  "prompt-template": "Prompt Template",
  talk: "Talk",
  lecture: "Lecture",
  article: "Article",
  fiction: "Fiction",
};

const videoTypes = new Set(["talk", "lecture", "presentation"]);
const mediaTypes = ["video", "text"] as const;
const mediaTypeLabels: Record<string, string> = {
  video: "Video",
  text: "Text",
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Resources — Protocolized",
  description:
    "Browse the full library of protocol-related resources: papers, frameworks, games, datasets, code, and more.",
  url: "https://protocolized.io/resources",
  itemListElement: resources.map((r, i) => ({
    "@type": "ListItem",
    position: i + 1,
    url: `https://protocolized.io/resources/${r.slug}`,
    name: r.title,
  })),
};
---

<Base
  title="Resources"
  description="Browse the full library of protocol-related resources: papers, frameworks, games, datasets, code, and more."
  jsonLd={jsonLd}
>
  <div class="py-12 px-6 lg:px-8">
    <div class="max-w-wide mx-auto">
      <!-- Page header -->
      <div class="mb-8">
        <h1 class="font-serif text-4xl text-dark mb-2">Resources</h1>
        <p class="font-sans text-secondary">
          <span id="resource-count">{resources.length}</span> resources on protocols
          — papers, frameworks, games, datasets, and more.
        </p>
      </div>

      <div class="flex flex-col lg:flex-row gap-8">
        <!-- Filters sidebar -->
        <aside class="lg:w-64 shrink-0" aria-label="Filter resources">
          <!-- Search -->
          <div class="mb-6">
            <label
              for="search-input"
              class="block text-xs font-sans font-medium text-secondary uppercase tracking-wider mb-2"
            >
              Search
            </label>
            <div class="relative">
              <input
                id="search-input"
                type="search"
                placeholder="Title, author, tag..."
                class="w-full pl-9 pr-4 py-2.5 text-sm font-sans border border-gray-200 rounded-lg bg-white focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary"
                aria-label="Search resources"
              />
              <svg
                class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-secondary"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
              </svg>
            </div>
          </div>

          <!-- Type filter -->
          <div class="mb-6">
            <p class="text-xs font-sans font-medium text-secondary uppercase tracking-wider mb-2">
              Type
            </p>
            <div class="flex flex-wrap gap-2">
              {
                allTypes.map((type) => (
                  <button
                    class="filter-pill font-sans text-xs px-3 py-1.5 rounded-full border border-gray-200 text-secondary hover:border-primary hover:text-primary transition-colors"
                    data-filter="type"
                    data-value={type}
                  >
                    {typeLabels[type] ?? type}
                  </button>
                ))
              }
            </div>
          </div>

          <!-- Media type filter -->
          <div class="mb-6">
            <p class="text-xs font-sans font-medium text-secondary uppercase tracking-wider mb-2">
              Media
            </p>
            <div class="flex flex-wrap gap-2">
              {
                mediaTypes.map((mt) => (
                  <button
                    class="filter-pill font-sans text-xs px-3 py-1.5 rounded-full border border-gray-200 text-secondary hover:border-primary hover:text-primary transition-colors"
                    data-filter="media"
                    data-value={mt}
                  >
                    {mediaTypeLabels[mt]}
                  </button>
                ))
              }
            </div>
          </div>

          <!-- Audience filter -->
          <div class="mb-6">
            <p class="text-xs font-sans font-medium text-secondary uppercase tracking-wider mb-2">
              Audience
            </p>
            <div class="flex flex-col gap-2">
              {
                allAudiences.map((audience) => (
                  <label class="flex items-center gap-2 cursor-pointer group">
                    <input
                      type="checkbox"
                      class="audience-checkbox sr-only"
                      data-value={audience}
                    />
                    <span class="w-4 h-4 rounded border-2 border-gray-300 group-has-[:checked]:border-primary group-has-[:checked]:bg-primary flex items-center justify-center shrink-0 transition-colors">
                      <svg
                        class="w-2.5 h-2.5 text-white hidden group-has-[:checked]:block"
                        fill="currentColor"
                        viewBox="0 0 20 20"
                      >
                        <path
                          fill-rule="evenodd"
                          d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                          clip-rule="evenodd"
                        />
                      </svg>
                    </span>
                    <span class="text-sm font-sans text-secondary capitalize group-has-[:checked]:text-dark transition-colors">
                      {audience}
                    </span>
                  </label>
                ))
              }
            </div>
          </div>

          <!-- Sort -->
          <div class="mb-6">
            <label
              for="sort-select"
              class="block text-xs font-sans font-medium text-secondary uppercase tracking-wider mb-2"
            >
              Sort
            </label>
            <select
              id="sort-select"
              class="w-full text-sm font-sans border border-gray-200 rounded-lg bg-white px-3 py-2.5 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary text-dark"
            >
              <option value="newest">Newest first</option>
              <option value="alphabetical">Alphabetical</option>
              <option value="featured">Featured first</option>
            </select>
          </div>

          <!-- Clear filters -->
          <button
            id="clear-filters"
            class="text-sm font-sans text-secondary hover:text-dark transition-colors hidden"
          >
            Clear all filters
          </button>
        </aside>

        <!-- Resource grid -->
        <div class="flex-1">
          <div
            id="resource-grid"
            class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5"
            role="region"
            aria-label="Resource results"
            aria-live="polite"
          >
            {
              resources.map((resource) => (
                <article
                  class="card p-5 flex flex-col gap-3 resource-item relative"
                  data-slug={resource.slug}
                  data-type={resource.type}
                  data-media-type={resource.mediaType}
                  data-tags={JSON.stringify(resource.tags)}
                  data-audience={JSON.stringify(resource.audience)}
                  data-title={resource.title.toLowerCase()}
                  data-description={resource.description.toLowerCase()}
                  data-authors={JSON.stringify(
                    resource.authors.map((a) => a.name.toLowerCase())
                  )}
                  data-date={resource.date}
                  data-featured={String(resource.featured)}
                >
                  <div class="flex items-start justify-between gap-2">
                    <BadgeType type={resource.type} />
                    {resource.featured && (
                      <span
                        class="badge font-sans text-[#D85A30]"
                        style="background-color:#FAECE7;"
                      >
                        Featured
                      </span>
                    )}
                  </div>
                  <div>
                    <h3 class="font-serif text-lg text-dark leading-snug mb-1">
                      <a
                        href={`/resources/${resource.slug}`}
                        class="hover:text-primary transition-colors after:absolute after:inset-0"
                      >
                        {resource.title}
                      </a>
                    </h3>
                    <p class="text-sm font-body text-secondary line-clamp-2 leading-relaxed">
                      {resource.description}
                    </p>
                  </div>
                  <div class="mt-auto flex items-center justify-between gap-2">
                    <div class="flex flex-wrap gap-1">
                      {resource.tags.slice(0, 3).map((tag) => (
                        <span class="text-xs font-sans text-secondary bg-gray-100 px-2 py-0.5 rounded-full">
                          {tag}
                        </span>
                      ))}
                    </div>
                    <time
                      datetime={resource.date}
                      class="text-xs font-sans text-secondary whitespace-nowrap shrink-0"
                    >
                      {new Date(resource.date).toLocaleDateString("en-US", {
                        year: "numeric",
                        month: "short",
                      })}
                    </time>
                  </div>
                  {resource.authors.length > 0 && (
                    <p class="text-xs font-sans text-secondary">
                      {resource.authors.map((a) => a.name).join(", ")}
                    </p>
                  )}
                </article>
              ))
            }
          </div>

          <!-- Empty state -->
          <div
            id="empty-state"
            class="hidden text-center py-16 text-secondary font-sans"
            role="status"
          >
            <p class="text-lg mb-2">No resources match your filters.</p>
            <p class="text-sm">Try adjusting your search or filter criteria.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</Base>

<script>
  // Filter state
  const state = {
    query: "",
    types: new Set<string>(),
    mediaTypes: new Set<string>(),
    audiences: new Set<string>(),
    sort: "newest",
  };

  // Read URL params on load
  const params = new URLSearchParams(window.location.search);
  const qParam = params.get("q");
  const typeParam = params.get("type");
  const audienceParam = params.get("audience");

  if (qParam) state.query = qParam;
  if (typeParam) state.types.add(typeParam);
  if (audienceParam) state.audiences.add(audienceParam);

  // DOM refs
  const searchInput = document.getElementById("search-input") as HTMLInputElement;
  const sortSelect = document.getElementById("sort-select") as HTMLSelectElement;
  const clearBtn = document.getElementById("clear-filters");
  const resourceCount = document.getElementById("resource-count");
  const grid = document.getElementById("resource-grid");
  const emptyState = document.getElementById("empty-state");
  const typePills = document.querySelectorAll<HTMLButtonElement>('[data-filter="type"]');
  const mediaPills = document.querySelectorAll<HTMLButtonElement>('[data-filter="media"]');
  const audienceCheckboxes = document.querySelectorAll<HTMLInputElement>(".audience-checkbox");

  // Initialize UI from URL state
  if (searchInput && state.query) searchInput.value = state.query;
  typePills.forEach((pill) => {
    if (state.types.has(pill.dataset.value ?? "")) {
      pill.classList.add("bg-primary", "text-white", "border-primary");
      pill.classList.remove("text-secondary", "border-gray-200");
    }
  });
  audienceCheckboxes.forEach((cb) => {
    if (state.audiences.has(cb.dataset.value ?? "")) {
      cb.checked = true;
    }
  });

  function updateURL() {
    const p = new URLSearchParams();
    if (state.query) p.set("q", state.query);
    if (state.types.size === 1) p.set("type", [...state.types][0]);
    if (state.audiences.size === 1) p.set("audience", [...state.audiences][0]);
    const newURL =
      window.location.pathname + (p.toString() ? "?" + p.toString() : "");
    window.history.replaceState({}, "", newURL);
  }

  function applyFilters() {
    const items = document.querySelectorAll<HTMLElement>(".resource-item");
    let visible = 0;

    const sortedItems = [...items].sort((a, b) => {
      if (state.sort === "newest") {
        return (
          new Date(b.dataset.date!).getTime() -
          new Date(a.dataset.date!).getTime()
        );
      } else if (state.sort === "alphabetical") {
        return (a.dataset.title ?? "").localeCompare(b.dataset.title ?? "");
      } else if (state.sort === "featured") {
        const aFeat = a.dataset.featured === "true" ? 0 : 1;
        const bFeat = b.dataset.featured === "true" ? 0 : 1;
        return aFeat - bFeat;
      }
      return 0;
    });

    sortedItems.forEach((item) => {
      grid?.appendChild(item);
    });

    items.forEach((item) => {
      const matchesQuery =
        !state.query ||
        (item.dataset.title ?? "").includes(state.query.toLowerCase()) ||
        (item.dataset.description ?? "").includes(state.query.toLowerCase()) ||
        JSON.parse(item.dataset.tags ?? "[]").some((t: string) =>
          t.toLowerCase().includes(state.query.toLowerCase())
        ) ||
        JSON.parse(item.dataset.authors ?? "[]").some((a: string) =>
          a.includes(state.query.toLowerCase())
        );

      const matchesType =
        state.types.size === 0 || state.types.has(item.dataset.type ?? "");

      const matchesMedia =
        state.mediaTypes.size === 0 || state.mediaTypes.has(item.dataset.mediaType ?? "");

      const matchesAudience =
        state.audiences.size === 0 ||
        JSON.parse(item.dataset.audience ?? "[]").some((a: string) =>
          state.audiences.has(a)
        );

      const show = matchesQuery && matchesType && matchesMedia && matchesAudience;
      item.style.display = show ? "" : "none";
      if (show) visible++;
    });

    if (resourceCount) resourceCount.textContent = String(visible);
    if (emptyState)
      emptyState.classList.toggle("hidden", visible > 0);
    if (grid) grid.classList.toggle("hidden", visible === 0);

    // Show/hide clear button
    const hasFilters =
      state.query || state.types.size > 0 || state.mediaTypes.size > 0 || state.audiences.size > 0;
    clearBtn?.classList.toggle("hidden", !hasFilters);

    updateURL();
  }

  // Search
  searchInput?.addEventListener("input", (e) => {
    state.query = (e.target as HTMLInputElement).value;
    applyFilters();
  });

  // Type pills
  typePills.forEach((pill) => {
    pill.addEventListener("click", () => {
      const value = pill.dataset.value ?? "";
      if (state.types.has(value)) {
        state.types.delete(value);
        pill.classList.remove("bg-primary", "text-white", "border-primary");
        pill.classList.add("text-secondary", "border-gray-200");
      } else {
        state.types.add(value);
        pill.classList.add("bg-primary", "text-white", "border-primary");
        pill.classList.remove("text-secondary", "border-gray-200");
      }
      applyFilters();
    });
  });

  // Media pills
  mediaPills.forEach((pill) => {
    pill.addEventListener("click", () => {
      const value = pill.dataset.value ?? "";
      if (state.mediaTypes.has(value)) {
        state.mediaTypes.delete(value);
        pill.classList.remove("bg-primary", "text-white", "border-primary");
        pill.classList.add("text-secondary", "border-gray-200");
      } else {
        state.mediaTypes.add(value);
        pill.classList.add("bg-primary", "text-white", "border-primary");
        pill.classList.remove("text-secondary", "border-gray-200");
      }
      applyFilters();
    });
  });

  // Audience checkboxes
  audienceCheckboxes.forEach((cb) => {
    cb.addEventListener("change", () => {
      const value = cb.dataset.value ?? "";
      if (cb.checked) {
        state.audiences.add(value);
      } else {
        state.audiences.delete(value);
      }
      applyFilters();
    });
  });

  // Sort
  sortSelect?.addEventListener("change", () => {
    state.sort = sortSelect.value;
    applyFilters();
  });

  // Clear
  clearBtn?.addEventListener("click", () => {
    state.query = "";
    state.types.clear();
    state.mediaTypes.clear();
    state.audiences.clear();
    if (searchInput) searchInput.value = "";
    typePills.forEach((pill) => {
      pill.classList.remove("bg-primary", "text-white", "border-primary");
      pill.classList.add("text-secondary", "border-gray-200");
    });
    mediaPills.forEach((pill) => {
      pill.classList.remove("bg-primary", "text-white", "border-primary");
      pill.classList.add("text-secondary", "border-gray-200");
    });
    audienceCheckboxes.forEach((cb) => (cb.checked = false));
    applyFilters();
  });

  // Run on load if URL params present
  if (state.query || state.types.size > 0 || state.audiences.size > 0) {
    applyFilters();
  }
</script>

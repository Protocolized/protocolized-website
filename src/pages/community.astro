---
import Base from "../layouts/Base.astro";
---

<Base
  title="Community"
  description="Join the Protocolized community on Discord, YouTube, and beyond. Connect with researchers, practitioners, and thinkers working on protocols."
>
  <div class="py-16 px-6 lg:px-8">
    <div class="max-w-prose mx-auto">
      <h1 class="font-serif text-5xl text-dark mb-4">Community</h1>
      <p class="font-body text-xl text-secondary mb-12 leading-relaxed">
        The work on protocols happens in public, in conversation. Join us.
      </p>

      <!-- Discord -->
      <section
        class="card p-8 mb-6"
        aria-labelledby="discord-heading"
      >
        <div class="flex items-start gap-5">
          <div class="shrink-0 w-12 h-12 bg-[#5865F2]/10 rounded-xl flex items-center justify-center">
            <svg
              class="w-6 h-6 text-[#5865F2]"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"
              ></path>
            </svg>
          </div>
          <div class="flex-1">
            <h2
              id="discord-heading"
              class="font-serif text-2xl text-dark mb-2"
            >
              Discord
            </h2>
            <p class="font-body text-secondary leading-relaxed mb-5">
              The Discord server is where the community happens: discussing
              resources, sharing new finds, coordinating research, and talking
              about protocol theory in practice. It's the fastest way to
              connect with others working in this space.
            </p>
            <a
              href="https://discord.gg/Aj5FbGsNYV"
              target="_blank"
              rel="noopener noreferrer"
              class="btn-primary"
            >
              Join the Discord →
            </a>
          </div>
        </div>
      </section>

      <!-- YouTube -->
      <section
        class="card p-8 mb-6"
        aria-labelledby="youtube-heading"
      >
        <div class="flex items-start gap-5">
          <div class="shrink-0 w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center">
            <svg
              class="w-6 h-6 text-red-600"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"
              ></path>
            </svg>
          </div>
          <div class="flex-1">
            <h2
              id="youtube-heading"
              class="font-serif text-2xl text-dark mb-2"
            >
              YouTube
            </h2>
            <p class="font-body text-secondary leading-relaxed mb-5">
              Talks, walkthroughs, discussions, and recorded events are on the
              Protocolized YouTube channel. Subscribe to catch new uploads.
            </p>
            <a
              href="https://www.youtube.com/@protocolized"
              target="_blank"
              rel="noopener noreferrer"
              class="btn-primary"
            >
              Visit YouTube channel →
            </a>
          </div>
        </div>
      </section>

      <!-- Events -->
      <section
        class="card p-8 mb-6 bg-surface"
        aria-labelledby="events-heading"
      >
        <h2 id="events-heading" class="font-serif text-2xl text-dark mb-2">
          Events
        </h2>
        <p class="font-body text-secondary leading-relaxed mb-4">
          Workshops, reading groups, and meetups are announced on the Discord
          server. There's no separate events calendar for now — join Discord to
          stay in the loop on upcoming gatherings.
        </p>
        <p class="font-body text-secondary leading-relaxed">
          Events are kept small and focused. The goal is real conversation, not
          broadcast.
        </p>
      </section>

      <!-- Newsletter cross-link -->
      <div class="mt-10 pt-10 border-t border-gray-100">
        <p class="font-sans text-secondary text-sm">
          For written updates and longer-form thinking, subscribe to the{" "}
          <a href="/newsletter" class="text-primary hover:text-[#085041] transition-colors">
            newsletter
          </a>
          .
        </p>
      </div>
    </div>
  </div>
</Base>
